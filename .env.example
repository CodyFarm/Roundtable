# Default provider when the frontend does not specify one.
# Options: gemini, openai, anthropic, deepseek, custom
DEFAULT_API_PROVIDER=deepseek

# Gemini (Google AI)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_API_MODEL="gpt-4o"
# OPENAI_API_BASE_URL="https://api.openai.com/v1"

# Anthropic (Claude)
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"
ANTHROPIC_API_MODEL="claude-3-5-sonnet-20241022"

# DeepSeek
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
DEEPSEEK_API_MODEL="deepseek-v4-pro"
DEEPSEEK_API_BASE_URL="https://api.deepseek.com/v1"

# Custom OpenAI-compatible provider
CUSTOM_API_KEY="MY_CUSTOM_API_KEY"
CUSTOM_API_MODEL=""
CUSTOM_API_BASE_URL=""

# The URL where this app is hosted.
APP_URL="MY_APP_URL"

# ── Turso (cloud SQLite) ──────────────────────────────────────────────
# Used for persistent data storage. If not configured, falls back to a
# local SQLite file at data/philo.db.
# Create a free database at https://turso.tech and run:
#   turso db create <name>
#   turso db show <name>        ← gives you the URL
#   turso db tokens create <name>  ← gives you the auth token
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-auth-token"
